{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/no-emoji-check.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/remind-korean-style.sh" },
          { "type": "command", "command": "bash .claude/hooks/remind-research-workflows.sh" }
        ]
      }
    ]
  }
}
